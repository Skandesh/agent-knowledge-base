{
  "name": "knowledge-brain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm --parallel --filter @knowledge-brain/api --filter @knowledge-brain/web dev",
    "dev:api": "pnpm --filter @knowledge-brain/api dev",
    "dev:web": "pnpm --filter @knowledge-brain/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "smoke": "pnpm --filter @knowledge-brain/api smoke",
    "eval": "pnpm --filter @knowledge-brain/api eval",
    "demo:check": "pnpm smoke && pnpm eval",
    "demo:prepare": "pnpm seed && pnpm reindex",
    "reindex": "pnpm --filter @knowledge-brain/api reindex",
    "seed": "pnpm --filter @knowledge-brain/api seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "tsx": "^4.19.4",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "vitest": "^3.1.2"
  }
}
