NODE_ENV=development
API_PORT=8787
WEB_PORT=5173
DATABASE_PATH=./data/knowledge-brain.sqlite
OPENSEARCH_NODE=http://localhost:9200
# Leave credential placeholders blank in committed files. Fill them only in your local .env.
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENAI_API_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
LLM_PROVIDER=openai
GENERATION_MODEL=gpt-5.5
RERANKER_PROVIDER=opensearch
OPENSEARCH_RERANK_PIPELINE=
OPENSEARCH_RERANK_MODEL=
STALE_SOURCE_HOURS=24
